generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MonthStatus {
  OPEN
  REVIEWED
  SETTLED
  LOCKED
}

enum RatioMode {
  AUTO_FROM_INCOME
  MANUAL
}

enum SplitType {
  MONTHLY_RATIO
  EQUAL
  PERSON_1_ONLY
  PERSON_2_ONLY
  CUSTOM_PERCENT
  EXCLUDED
}

enum CurrencyCode {
  HUF
  EUR
  USD
  GBP
  CHF
  CZK
  PLN
  OTHER
}

model Person {
  id            String   @id @default(cuid())
  name          String
  displayOrder  Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  paidExpenses  Expense[] @relation("ExpensePaidBy")
  customSplits  ExpenseCustomSplit[]
  incomeSources IncomeSource[]
  monthlyIncomes MonthlyIncome[]
}

model Month {
  id              String      @id @default(cuid())
  monthKey        String      @unique
  person1RatioBps Int?
  person2RatioBps Int?
  ratioMode       RatioMode   @default(AUTO_FROM_INCOME)
  status          MonthStatus @default(OPEN)
  settlementNote  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  expenses        Expense[]
  monthlyIncomes  MonthlyIncome[]

  @@index([monthKey])
}

model IncomeSource {
  id                String   @id @default(cuid())
  personId          String
  person            Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  name              String
  defaultAmountHufMinor Int?
  isEnabled         Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  monthlyIncomes    MonthlyIncome[]

  @@index([personId])
}

model MonthlyIncome {
  id                String   @id @default(cuid())
  monthKey          String
  month             Month    @relation(fields: [monthKey], references: [monthKey], onDelete: Cascade)
  personId          String
  person            Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  incomeSourceId    String
  incomeSource      IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)
  amountHufMinor    Int?
  isIncluded        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([monthKey, incomeSourceId])
  @@index([monthKey])
  @@index([personId])
}

model Expense {
  id                    String       @id @default(cuid())
  date                  DateTime
  monthKey              String
  month                 Month        @relation(fields: [monthKey], references: [monthKey])
  description           String

  amountOriginalMinor   Int
  currency              CurrencyCode @default(HUF)
  currencyMinorUnit     Int          @default(2)
  exchangeRateToHufMicros Int        @default(1000000)
  amountHufMinor        Int

  paidByPersonId        String
  paidByPerson          Person       @relation("ExpensePaidBy", fields: [paidByPersonId], references: [id])
  splitType             SplitType    @default(MONTHLY_RATIO)

  categoryId            String?
  category              Category?    @relation(fields: [categoryId], references: [id])
  note                  String?
  customSplits          ExpenseCustomSplit[]

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deletedAt             DateTime?

  @@index([monthKey])
  @@index([date])
  @@index([paidByPersonId])
  @@index([splitType])
  @@index([currency])
}

model ExpenseCustomSplit {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  personId  String
  person    Person  @relation(fields: [personId], references: [id])
  ratioBps  Int?
  amountHufMinor Int?

  @@unique([expenseId, personId])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  icon      String?
  color     String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AppSetting {
  id           String       @id @default(cuid())
  baseCurrency CurrencyCode @default(HUF)
  locale       String       @default("en-US")
  timezone     String       @default("Europe/Budapest")
  person1Id    String?
  person2Id    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
